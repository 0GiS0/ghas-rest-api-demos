    "name": "Demo 1 - PAT Authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Coleccion equivalente a 01-pat-authentication/ghas-api.http"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://api.github.com"
    },
    {
      "key": "apiVersion",
      "value": "2022-11-28"
    }
  ],
  "item": [
    {
      "name": "Verificar autenticacion",
      "item": [
        {
          "name": "Obtener usuario autenticado",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_01}}"
              },
              {
                "key": "Accept",
                "value": "application/vnd.github+json"
              },
              {
                "key": "X-GitHub-Api-Version",
                "value": "{{apiVersion}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "user"
              ]
            },
            "description": "Verifica que el token funciona y muestra el usuario autenticado."
          },
          "response": []
        },
        {
          "name": "Verificar organizacion",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_01}}"
              },
              {
                "key": "Accept",
                "value": "application/vnd.github+json"
              },
              {
                "key": "X-GitHub-Api-Version",
                "value": "{{apiVersion}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{GITHUB_ORG}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{GITHUB_ORG}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Listar repos visibles de la org",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_01}}"
              },
              {
                "key": "Accept",
                "value": "application/vnd.github+json"
              },
              {
                "key": "X-GitHub-Api-Version",
                "value": "{{apiVersion}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{GITHUB_ORG}}/repos?per_page=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{GITHUB_ORG}}",
                "repos"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            },
            "description": "Si devuelve [] o no aparece tu repo, las llamadas GHAS del repo darán 404."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Code Scanning",
      "item": [
        {
          "name": "Listar alertas org",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_01}}"
              },
              {
