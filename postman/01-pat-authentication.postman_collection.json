            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{GITHUB_ORG}}/code-scanning/alerts?per_page=10&state=open",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{GITHUB_ORG}}",
                "code-scanning",
                "alerts"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "10"
                },
                {
                  "key": "state",
                  "value": "open"
                }
              ]
            },
            "description": "Requiere ser owner o security manager de la organizacion. GitHub devuelve 404 tambien cuando el recurso existe pero no tienes acceso suficiente."
          },
          "response": []
