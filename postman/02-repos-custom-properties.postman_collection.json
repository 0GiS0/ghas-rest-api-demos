  "item": [
    {
      "name": "Paso 1 - Consultar esquema",
      "item": [
        {
          "name": "Listar schema de custom properties",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_02}}"
              },
              {
                "key": "Accept",
                "value": "application/vnd.github+json"
              },
              {
                "key": "X-GitHub-Api-Version",
                "value": "{{apiVersion}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orgs/{{GITHUB_ORG}}/properties/schema",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{GITHUB_ORG}}",
                "properties",
                "schema"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Paso 2 - Crear custom properties",
      "item": [
        {
          "name": "Crear o actualizar schema",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{GITHUB_TOKEN_DEMO_02}}"
              },
              {
                "key": "Accept",
                "value": "application/vnd.github+json"
              },
              {
                "key": "X-GitHub-Api-Version",
                "value": "{{apiVersion}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"properties\": [\n    {\n      \"property_name\": \"application_type\",\n      \"value_type\": \"single_select\",\n      \"required\": false,\n      \"description\": \"Tipo de aplicacion del repositorio\",\n      \"allowed_values\": [\n        \"mobile\",\n        \"web\",\n        \"desktop\"\n      ],\n      \"values_editable_by\": \"org_and_repo_actors\"\n    },\n    {\n      \"property_name\": \"mobile_platform\",\n      \"value_type\": \"single_select\",\n      \"required\": false,\n      \"description\": \"Plataforma de la app movil. Dejala vacia para repos web o desktop\",\n      \"allowed_values\": [\n        \"android\",\n        \"ios\"\n      ],\n      \"values_editable_by\": \"org_and_repo_actors\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orgs/{{GITHUB_ORG}}/properties/schema",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orgs",
                "{{GITHUB_ORG}}",
                "properties",
                "schema"
              ]
            }
          },
          "response": []
        }
      ]
    },
