# GitHub Configuration
GITHUB_ORG=your-organization-name

# Demo 1: PAT Authentication and direct GHAS API checks
GITHUB_TOKEN_DEMO_01=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Demo 2: Custom properties schema and values
GITHUB_TOKEN_DEMO_02=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Demo 3: GHAS alerts filtered by custom properties
GITHUB_TOKEN_DEMO_03=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Demo 4: PDF report generation
GITHUB_TOKEN_DEMO_04=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Demo 5: GitHub App Authentication
# Create a GitHub App following the instructions in 05-github-app-authentication/README.md
GITHUB_APP_ID=123456
GITHUB_APP_INSTALLATION_ID=12345678
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem

# ============================================
# Fine-Grained Token Guidance
# ============================================
#
# Create a fine-grained PAT at:
# https://github.com/settings/personal-access-tokens/new
#
# WARNING:
# If you are going to query repositories or GHAS alerts from an organization,
# the PAT must be created with that organization selected as the Resource owner.
# It is not enough to create the token from the settings of a user who is Owner
# of the organization. If the Resource owner is your personal account instead of
# the org, requests like /orgs/{org}/repos or /orgs/{org}/code-scanning/alerts
# can return [] or 404 even when the user belongs to the org.
#
# Demo 1 PAT:
#   Repository permissions:
#     - Code scanning alerts: Read
#     - Dependabot alerts: Read
#     - Secret scanning alerts: Read
#     - Metadata: Read
#     - Repository security advisories: Write (only if you want the last org advisory request)
#
# Demo 2 PAT:
#   Repository permissions:
#     - Custom properties: Read and write
#     - Metadata: Read
#   Organization permissions:
#     - Custom properties: Read and write
#
# Demo 3 PAT:
#   Repository permissions:
#     - Code scanning alerts: Read
#     - Dependabot alerts: Read
#     - Secret scanning alerts: Read
#     - Custom properties: Read
#     - Metadata: Read
#   Organization permissions:
#     - Custom properties: Read
#
# Demo 4 PAT:
#   Same permissions as Demo 3
